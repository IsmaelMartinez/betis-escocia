# =============================================================================
# BETIS ESCOCIA - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the required values.
# Variables with default values shown can be omitted if the default is acceptable.
# =============================================================================

# -----------------------------------------------------------------------------
# FOOTBALL DATA API
# -----------------------------------------------------------------------------
# Required for match/standings data: https://www.football-data.org/
FOOTBALL_DATA_API_KEY=your-api-key
# Optional: API endpoint (default shown)
FOOTBALL_DATA_API_URL=https://api.football-data.org/v4
# Optional: Rate limiting (defaults shown)
API_RATE_LIMIT_PER_MINUTE=10
API_CACHE_TTL_HOURS=24
API_CACHE_TTL_LIVE_HOURS=1

# -----------------------------------------------------------------------------
# SENTRY ERROR MONITORING
# -----------------------------------------------------------------------------
# Required for error tracking: https://sentry.io/
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# Optional: Release identifier for Sentry
NEXT_PUBLIC_SENTRY_RELEASE=

# -----------------------------------------------------------------------------
# GOOGLE SERVICES
# -----------------------------------------------------------------------------
# Optional: Google Search Console verification
GOOGLE_SITE_VERIFICATION=

# -----------------------------------------------------------------------------
# FEATURE FLAGS
# -----------------------------------------------------------------------------
# All feature flags have sensible defaults. Only set to override.
# Values: "true" or "false" (case-insensitive, but only "true" enables)
# Source of truth: src/lib/features/featureFlags.ts
#
# Default: false - Set to "true" to enable
NEXT_PUBLIC_FEATURE_DEBUG_INFO=false

# Default: true - Core features enabled by default (set to "false" to disable)
NEXT_PUBLIC_FEATURE_NOSOTROS=true
NEXT_PUBLIC_FEATURE_UNETE=true
NEXT_PUBLIC_FEATURE_CLASIFICACION=true
NEXT_PUBLIC_FEATURE_PARTIDOS=true
NEXT_PUBLIC_FEATURE_JUGADORES_HISTORICOS=true
NEXT_PUBLIC_FEATURE_EFEMERIDES=true
